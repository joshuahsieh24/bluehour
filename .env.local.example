# Bluehour environment variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# CloudFront domain for ambient audio files.
# Get this value from: cd infra/bluehour && terraform output cloudfront_domain
# Leave unset for local dev — the app falls back to /audio (local public/ files).
NEXT_PUBLIC_AUDIO_CDN=https://xxxxxxxxxxxx.cloudfront.net
